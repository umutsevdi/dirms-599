# Disaster Management System API Configuration

# App
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/disaster_mgmt

# CORS (Frontend URLs)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Email Backend
# Options:
#   - "console": Logs emails to console (development only)
#   - "resend": Sends emails via Resend API (production)
EMAIL_BACKEND=console

# From email address
# For Resend: Must be a verified domain in your Resend account
# Example: "login@yourdomain.com"
FROM_EMAIL=noreply@disaster-mgmt.local

# Resend Configuration (required when EMAIL_BACKEND=resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=
